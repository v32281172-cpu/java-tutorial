public class evensumoddsum {
    public static void main(String[] args) {
        int []arr={1,2,3,4,5,6};
        int oddsum=0;
        int evensum=0;
        for(int num:arr){
            if (num % 2 == 0) {
                evensum+=num;
            }
            else if(num%2!=0){
                oddsum+=num;
            }
        }
        System.out.println("Evensum: "+ evensum);
        System.out.println("Oddsum: "+ oddsum);
    }
}
