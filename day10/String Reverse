import java.util.*;
public class stringreverse {
    public static void main(String[] args) {
        String name = "hello world";
        char[] ch = name.toCharArray();
        char start = 0;
        int end=ch.length-1;
       while(start<=end){
                char temp = ch[start];
                ch[start]= ch[end];
                ch[end] = temp;
                start++;
                end--;
            }
            String s=new String(ch);
            System.out.println(s.equals(s)?"yes":"no");

    }
}
