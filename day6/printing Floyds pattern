import java.util.*;
public class FloysTriangle {
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=5;
        int num=1;
        for(int i=1;i<=n;i++){
            for(int j=1;j<=i;j++){
                System.out.printf("%4d",num++);
            }
            System.out.println();
        }
    }
}
