import java.util.Scanner;
public class squarewithalphabet {
    public static void main(String [] args){
        Scanner sc=new Scanner(System.in);
        char  ch='a';
        for(int i=1;i<=5;i++){
            for(int j=1;j<=5;j++){
                System.out.print(ch);
                ch++;
            }
            System.out.println();
        }
    }
}
