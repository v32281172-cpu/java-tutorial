import java.util.*;
public class nestedif {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int num = sc.nextInt();
        if (num % 3 == 0) {
            if (num % 5 == 0) {
                System.out.println("helloo");
            } else {
                System.out.println("not divisible");
            }
        }
    }
}
