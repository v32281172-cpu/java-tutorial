import java.util.*;
public class check_frequency {
    public static void main(String[] args){
        Scanner rs=new Scanner(System.in);
        int num=rs.nextInt();
        int key=rs.nextInt();
        int count=0;
        while(num!=0){
            int pop=num%10;
            if(pop==key){
                count++;
            }
            num=num/10;
        }
        System.out.println(count);
    }
}
